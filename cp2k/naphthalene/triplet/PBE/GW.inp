&GLOBAL
  PROJECT  Open
  PRINT_LEVEL MEDIUM
  RUN_TYPE ENERGY
  &TIMINGS
     THRESHOLD 0.0001
  &END
&END GLOBAL
&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME /scratch/hpc-prf-metdyn/metdyn02_Remi/05_Dyson_orbitals/cp2k/def2-TZVP
    BASIS_SET_FILE_NAME /scratch/hpc-prf-metdyn/metdyn02_Remi/05_Dyson_orbitals/cp2k/def2-TZVP-RIFIT
    SORT_BASIS EXP
    POTENTIAL_FILE_NAME  /pc2/groups/hpc-prf-metdyn/metdyn02_Remi/cp2k/cp2k/data/ALL_POTENTIALS 
    CHARGE 0
    &MGRID
      CUTOFF  1000
      REL_CUTOFF  100
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER WAVELET
    &END POISSON
    &QS
      METHOD GAPW
      EPS_DEFAULT 1.0E-12
      EPS_PGF_ORB 1.0E-12
    &END QS
    &SCF
      SCF_GUESS ATOMIC
      EPS_SCF 1.0E-6
      MAX_SCF 500
      &PRINT
        &RESTART ON
        &END
      &END
      ADDED_MOS -1 -1
      &MIXING
          METHOD BROYDEN_MIXING
          ALPHA 0.1
          BETA 1.5
          NBROYDEN 8
      &END
      CHOLESKY OFF
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &WF_CORRELATION
      	&RI_RPA
	  QUADRATURE_POINTS 100
      	  &GW
	    CORR_MOS_OCC 10
	    CORR_MOS_VIRT 10
	    SELF_CONSISTENCY evGW0
          &END GW	
        &END RI_RPA
      &END WF_CORRELATION
    &END XC
    UKS
    MULTIPLICITY 3
   &PRINT
      &MO_CUBES
        WRITE_CUBE T
        NHOMO 10
        NLUMO 10
      &END MO_CUBES
    &END PRINT
  &END DFT
    &SUBSYS
    &CELL
      ABC                 30 30 30
      ALPHA_BETA_GAMMA    90 90 90
      PERIODIC NONE
    &END CELL

     &KIND C
      BASIS_SET ORB def2-TZVP
      BASIS_SET RI_AUX def2-TZVP-RIFIT
      POTENTIAL ALL
     &END KIND

     &KIND H
      BASIS_SET ORB def2-TZVP
      BASIS_SET RI_AUX def2-TZVP-RIFIT
      POTENTIAL ALL
     &END KIND

     &KIND N
      BASIS_SET ORB def2-TZVP
      BASIS_SET RI_AUX def2-TZVP-RIFIT
      POTENTIAL ALL
     &END KIND


    &TOPOLOGY
     &CENTER_COORDINATES T
     &END CENTER_COORDINATES
    &END TOPOLOGY


